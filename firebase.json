{
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "BREN Finance",
        "supportEmail": "suporte@bren.app",
        "authorizedRedirectUris": ["http://localhost"]
      }
    }
  },
  "hosting": {
    "site": "fin-bren",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/bren_finance_app.html"
      }
    ]
  }
}
